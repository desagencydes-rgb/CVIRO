<?xml version="1.0" encoding="UTF-8"?>
<Context>

    <!--
        JNDI DataSource: jdbc/cvgen
        ════════════════════════════════════════════════════════════════
        Currently configured for H2 in-memory (development / default).

        TO SWITCH TO SUPABASE / POSTGRESQL:
        1. Replace driverClassName → org.postgresql.Driver
        2. Replace url           → jdbc:postgresql://<host>:<port>/<dbname>?sslmode=require
        3. Replace username/password with your Supabase credentials
        4. Make sure postgresql-*.jar is in WEB-INF/lib (handled by Maven)
        ════════════════════════════════════════════════════════════════
    -->
    <Resource
        name="jdbc/cvgen"
        auth="Container"
        type="javax.sql.DataSource"
        maxTotal="20"
        maxIdle="10"
        maxWaitMillis="10000"

        driverClassName="org.postgresql.Driver"
        url="jdbc:postgresql://aws-1-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require"
        username="postgres.ieulwgaexrsnpncjkjas"
        password="Ray.hunt.elh.cor.astra34@"

        validationQuery="SELECT 1"
        testOnBorrow="true"
    />

    <!-- PostgreSQL / Supabase (uncomment and replace values if needed):
