<?xml version="1.0" encoding="UTF-8"?>
<Context>

    <!--
        JNDI DataSource: jdbc/cvgen
        ════════════════════════════════════════════════════════════════
        H2 embedded database — local development (zero configuration).
        Data is stored in a file so it persists across restarts.

        TO SWITCH TO SUPABASE / POSTGRESQL:
        1. Comment out the H2 Resource block below
        2. Uncomment the PostgreSQL Resource block at the bottom
        3. Fill in your Supabase host, username, and password
        ════════════════════════════════════════════════════════════════
    -->

    <!-- ── H2 Embedded (DEFAULT — works out of the box locally) ─────── -->
    <Resource
        name="jdbc/cvgen"
        auth="Container"
        type="jakarta.sql.DataSource"
        maxTotal="20"
        maxIdle="10"
        maxWaitMillis="10000"
        driverClassName="org.h2.Driver"
        url="jdbc:h2:file:${user.home}/.cvpro/db/cvgen;AUTO_SERVER=TRUE;AUTO_RECONNECT=TRUE"
        username="sa"
        password=""
        validationQuery="SELECT 1"
        testOnBorrow="true"
    />

